# Public URL used in the browser. When this host differs from the Next app (e.g. localhost),
# requests automatically go through the same-origin proxy at /api/proxy.
NEXT_PUBLIC_API_BASE_URL=https://maxtronize-api.maxtron.ai

# Server-only backend origin for /api/proxy (optional; falls back to NEXT_PUBLIC_API_BASE_URL).
API_BASE_URL=https://maxtronize-api.maxtron.ai
